<?xml version="1.0" encoding="UTF-8"?>
<chapter xml:id="ch-four-chord-grids" xmlns:xi="http://www.w3.org/2001/XInclude">
  <title>Four-Chord-Grids</title>
  <introduction>
    <p>Four split isometric chord grids. Nodes shaded with fill=gray!50 mark the selected
    chord tones; the corresponding minim (half-note) chord appears in the treble
    notation below each grid, generated with LilyPond.</p>
  </introduction>

  <!-- Row 1: C major and G major -->
  <figure xml:id="fig-chord-grids-row1">
    <caption>C major (left) and G major (right) chord grids. Shaded nodes are the selected chord tones.</caption>
    <sidebyside widths="47% 47%" margins="3%">

      <!-- Grid 1: C major — selected: C(5,1.5), E(4,3), G(4,4) -->
      <stack>
        <image xml:id="img-grid-c-major">
          <latex-image>
\begin{tikzpicture}[scale=0.66, transform shape]
\pgfmathsetmacro{\isoangle}{60}
\pgfmathsetmacro{\vv}{8}
\pgfmathsetmacro{\hh}{6}
\pgfmathsetmacro{\vlen}{1.5}
\pgfmathsetmacro{\ang}{\isoangle/2}
\pgfmathsetmacro{\dlen}{(\vlen/2) / sin(\ang)}
\pgfmathsetmacro{\hlen}{(\vlen/2) / tan(\ang)}
\pgfmathsetmacro{\xmax}{\hh*\hlen}
\pgfmathsetmacro{\ymax}{\vv*\vlen}
\drawgridandnotes
% C major chord tones (fill=gray!50)
\node[circle, draw=gray, fill=gray!50, inner sep=1pt, minimum size=40pt] at (5*\hlen,1.5*\vlen) {C};
\node[circle, draw=gray, fill=gray!50, inner sep=1pt, minimum size=40pt] at (4*\hlen,3*\vlen) {E};
\node[circle, draw=gray, fill=gray!50, inner sep=1pt, minimum size=40pt] at (4*\hlen,4*\vlen) {G};
\end{tikzpicture}
          </latex-image>
        </image>
        <image xml:id="img-notation-c-major" source="notation/chord-c-major">
          <shortdescription>C major half-note chord: C, E, G on treble staff</shortdescription>
        </image>
      </stack>

      <!-- Grid 2: G major — selected: G(4,4), B(3,5.5), D(3,6.5) -->
      <stack>
        <image xml:id="img-grid-g-major">
          <latex-image>
\begin{tikzpicture}[scale=0.66, transform shape]
\pgfmathsetmacro{\isoangle}{60}
\pgfmathsetmacro{\vv}{8}
\pgfmathsetmacro{\hh}{6}
\pgfmathsetmacro{\vlen}{1.5}
\pgfmathsetmacro{\ang}{\isoangle/2}
\pgfmathsetmacro{\dlen}{(\vlen/2) / sin(\ang)}
\pgfmathsetmacro{\hlen}{(\vlen/2) / tan(\ang)}
\pgfmathsetmacro{\xmax}{\hh*\hlen}
\pgfmathsetmacro{\ymax}{\vv*\vlen}
\drawgridandnotes
% G major chord tones (fill=gray!50)
\node[circle, draw=gray, fill=gray!50, inner sep=1pt, minimum size=40pt] at (4*\hlen,4*\vlen) {G};
\node[circle, draw=gray, fill=gray!50, inner sep=1pt, minimum size=40pt] at (3*\hlen,5.5*\vlen) {B};
\node[circle, draw=gray, fill=gray!50, inner sep=1pt, minimum size=40pt] at (3*\hlen,6.5*\vlen) {D};
\end{tikzpicture}
          </latex-image>
        </image>
        <image xml:id="img-notation-g-major" source="notation/chord-g-major">
          <shortdescription>G major half-note chord: G, B, D on treble staff</shortdescription>
        </image>
      </stack>

    </sidebyside>
  </figure>

  <!-- Row 2: F major and A minor -->
  <figure xml:id="fig-chord-grids-row2">
    <caption>F major (left) and A minor (right) chord grids. Shaded nodes are the selected chord tones.</caption>
    <sidebyside widths="47% 47%" margins="3%">

      <!-- Grid 3: F major — selected: F(3,3.5), A(2,5), C(2,6) -->
      <stack>
        <image xml:id="img-grid-f-major">
          <latex-image>
\begin{tikzpicture}[scale=0.66, transform shape]
\pgfmathsetmacro{\isoangle}{60}
\pgfmathsetmacro{\vv}{8}
\pgfmathsetmacro{\hh}{6}
\pgfmathsetmacro{\vlen}{1.5}
\pgfmathsetmacro{\ang}{\isoangle/2}
\pgfmathsetmacro{\dlen}{(\vlen/2) / sin(\ang)}
\pgfmathsetmacro{\hlen}{(\vlen/2) / tan(\ang)}
\pgfmathsetmacro{\xmax}{\hh*\hlen}
\pgfmathsetmacro{\ymax}{\vv*\vlen}
\drawgridandnotes
% F major chord tones (fill=gray!50)
\node[circle, draw=gray, fill=gray!50, inner sep=1pt, minimum size=40pt] at (3*\hlen,3.5*\vlen) {F};
\node[circle, draw=gray, fill=gray!50, inner sep=1pt, minimum size=40pt] at (2*\hlen,5*\vlen) {A};
\node[circle, draw=gray, fill=gray!50, inner sep=1pt, minimum size=40pt] at (2*\hlen,6*\vlen) {C};
\end{tikzpicture}
          </latex-image>
        </image>
        <image xml:id="img-notation-f-major" source="notation/chord-f-major">
          <shortdescription>F major half-note chord: F, A, C on treble staff</shortdescription>
        </image>
      </stack>

      <!-- Grid 4: A minor — selected: A(5,4.5), C(5,5.5), E(4,7) -->
      <stack>
        <image xml:id="img-grid-a-minor">
          <latex-image>
\begin{tikzpicture}[scale=0.66, transform shape]
\pgfmathsetmacro{\isoangle}{60}
\pgfmathsetmacro{\vv}{8}
\pgfmathsetmacro{\hh}{6}
\pgfmathsetmacro{\vlen}{1.5}
\pgfmathsetmacro{\ang}{\isoangle/2}
\pgfmathsetmacro{\dlen}{(\vlen/2) / sin(\ang)}
\pgfmathsetmacro{\hlen}{(\vlen/2) / tan(\ang)}
\pgfmathsetmacro{\xmax}{\hh*\hlen}
\pgfmathsetmacro{\ymax}{\vv*\vlen}
\drawgridandnotes
% A minor chord tones (fill=gray!50)
\node[circle, draw=gray, fill=gray!50, inner sep=1pt, minimum size=40pt] at (5*\hlen,4.5*\vlen) {A};
\node[circle, draw=gray, fill=gray!50, inner sep=1pt, minimum size=40pt] at (5*\hlen,5.5*\vlen) {C};
\node[circle, draw=gray, fill=gray!50, inner sep=1pt, minimum size=40pt] at (4*\hlen,7*\vlen) {E};
\end{tikzpicture}
          </latex-image>
        </image>
        <image xml:id="img-notation-a-minor" source="notation/chord-a-minor">
          <shortdescription>A minor half-note chord: A, C, E on treble staff</shortdescription>
        </image>
      </stack>

    </sidebyside>
  </figure>

