<?xml version="1.0" encoding="UTF-8"?>
<chapter xml:id="ch-iso-grid-treble" xmlns:xi="http://www.w3.org/2001/XInclude">
  <title>Iso-Grid Treble</title>
  <introduction>
    <p>
      Treble-hand isometric grid rotated 90 degrees clockwise, with treble staff above aligned to the grid columns.
      Horizontal columns are labelled 1 to 5, with the TOP legend on the left.
    </p>
  </introduction>

  <section xml:id="sec-iso-grid-treble-main">
    <title>Treble Isometric Grid</title>

    <figure xml:id="fig-iso-grid-treble">
      <caption>Treble-hand isometric grid rotated 90 degrees clockwise with aligned treble staff above.</caption>
      <image xml:id="img-iso-grid-treble">
        <latex-image>
% -----------------------------------------------------------------------
% Iso-Grid Treble  –  treble RH grid (90 deg CW rotation) with staff above
%
% Same parameters as the bass/treble scale template RH side:
%   isoangle=60, vlen=1.5cm, scale=0.75, hh=8 segments, vv=10 node rows
%   hlen = vlen*sqrt(3)/2 = 1.299038 cm
%   After rotation: x-spacing (half-step) = 0.5*vlen*scale*28.3465 = 15.9449 pt
%                   row-height (hlen_scaled) = hlen*scale*28.3465  = 27.6174 pt
%
% In the rotated frame:
%   5 horizontal rows  (old peg columns p=1..5; p=5 at bottom, p=1 at top)
%   Node at (r,p): x = xstart + (2r + 6-p - 3) * halfstep
%                  y = (5-p) * hlen_pt
%   Chromatic note at (r,p): semitone = ((r-1)*3 + (5-p)) mod 12  above C4
%
% Vertical column lines at every half-step pass through one node per active row.
% Staff above: one note head per column, chromatic from C4 (col k=3) upward.
% -----------------------------------------------------------------------
\begin{tikzpicture}[scale=0.75, transform shape]
\pgfmathsetmacro{\isoangle}{60}
\pgfmathsetmacro{\vlen}{1.5}           % cm – row width after rotation
\pgfmathsetmacro{\ang}{\isoangle/2}   % 30 deg
\pgfmathsetmacro{\hlen}{(\vlen/2)/tan(\ang)}  % ~1.299 cm – row height after rotation
\pgfmathsetmacro{\halfstep}{\vlen/2}   % 0.75 cm – basic column unit
\pgfmathsetmacro{\nrows}{5}            % peg rows (p=1 top .. p=5 bottom)
\pgfmathsetmacro{\ncyc}{10}            % 10 node cycles along bottom row
% Grid extents (cm)
\pgfmathsetmacro{\gridH}{(\nrows-1)*\hlen}          % vertical span 4*hlen
\pgfmathsetmacro{\kmin}{3}                           % first column index k
\pgfmathsetmacro{\kmax}{21}                          % last column index k  (bottom row r=10)
\pgfmathsetmacro{\gridW}{(\kmax-\kmin)*\halfstep}   % = 18*0.75 = 13.5 cm
\pgfmathsetmacro{\xleft}{0}
\pgfmathsetmacro{\xright}{\gridW}
\pgfmathsetmacro{\ybottom}{0}
\pgfmathsetmacro{\ytop}{\gridH}
% Helper: x position for column index k
% x(k) = (k - kmin)*halfstep

% ---- Isometric grid lines (clipped) ----
\begin{scope}
  \clip (\xleft-0.01, \ybottom-0.01) rectangle (\xright+0.01, \ytop+0.01);

  % Horizontal row lines at y = (5-p)*hlen for p=1..5 and half-boundary lines
  \foreach \p in {1,...,5} {
    \pgfmathsetmacro{\yy}{(5-\p)*\hlen}
    \draw[gray, thin] (\xleft, \yy) -- (\xright, \yy);
  }

  % Vertical column lines at x = (k-kmin)*halfstep for k=kmin..kmax (every half-step)
  \foreach \k in {3,...,21} {
    \pgfmathsetmacro{\xx}{(\k-3)*\halfstep}
    \draw[lightgray, very thin] (\xx, \ybottom) -- (\xx, \ytop);
  }

  % Diagonal family 1: at +60 deg from horizontal (bottom-left to top-right in rotated frame)
  % These connect adjacent nodes diagonally (iso up-right direction).
  % Start points along the bottom edge and left edge, spaced by vlen (2*halfstep).
  \pgfmathsetmacro{\diaglen}{(\gridW + \gridH + \vlen) * 1.5}
  \foreach \ki in {1,...,12} {
    \pgfmathsetmacro{\startx}{(\ki-1)*\vlen}
    \draw[lightgray, very thin]
      (\startx, \ybottom) -- ({\startx + \diaglen*cos(60)}, {\ybottom + \diaglen*sin(60)});
  }
  \foreach \pi in {1,...,5} {
    \pgfmathsetmacro{\starty}{(\pi-1)*\hlen}
    \draw[lightgray, very thin]
      (\xleft, \starty) -- ({0 + \diaglen*cos(60)}, {\starty + \diaglen*sin(60)});
  }

  % Diagonal family 2: at -60 deg (top-left to bottom-right in rotated frame)
  \foreach \ki in {0,...,12} {
    \pgfmathsetmacro{\startx}{\ki*\vlen}
    \draw[lightgray, very thin]
      (\startx, \ytop) -- ({\startx + \diaglen*cos(-60)}, {\ytop + \diaglen*sin(-60)});
  }
  \foreach \pi in {1,...,5} {
    \pgfmathsetmacro{\starty}{(\pi-1)*\hlen}
    \draw[lightgray, very thin]
      (\xleft, \starty + \hlen*4) -- ({0 + \diaglen*cos(-60)}, {\starty + \hlen*4 + \diaglen*sin(-60)});
  }

\end{scope}

% Outer border
\draw[gray, thin] (\xleft, \ybottom) rectangle (\xright, \ytop);

% ---- Node circles at each (r, p) intersection ----
% x(r,p) = (2r + (6-p) - kmin) * halfstep = (2r + 6 - p - 3) * halfstep = (2r + 3 - p)*halfstep
% y(r,p) = (5-p)*hlen
% Chromatic notes: semitone = ((r-1)*3 + (5-p)) mod 12 above C4
% notes in order: C, C#/Db, D, Eb/D#, E, F, F#/Gb, G, Ab/G#, A, Bb/A#, B

% Row p=5 (bottom, y=0), r=1..10 – C at r=1,5,9; others plain
\node[circle,draw=gray,fill=gray!50,inner sep=0pt,minimum size=38pt] at ({(2*1+3-5)*\halfstep},{(5-5)*\hlen}) {\footnotesize C};
\node[circle,draw=gray,fill=gray!10,inner sep=0pt,minimum size=38pt] at ({(2*2+3-5)*\halfstep},{(5-5)*\hlen}) {\footnotesize E$\flat$};
\node[circle,draw=gray,fill=gray!10,inner sep=0pt,minimum size=38pt] at ({(2*3+3-5)*\halfstep},{(5-5)*\hlen}) {\footnotesize F$\sharp$};
\node[circle,draw=gray,fill=gray!10,inner sep=0pt,minimum size=38pt] at ({(2*4+3-5)*\halfstep},{(5-5)*\hlen}) {\footnotesize A};
\node[circle,draw=gray,fill=gray!50,inner sep=0pt,minimum size=38pt] at ({(2*5+3-5)*\halfstep},{(5-5)*\hlen}) {\footnotesize C};
\node[circle,draw=gray,fill=gray!10,inner sep=0pt,minimum size=38pt] at ({(2*6+3-5)*\halfstep},{(5-5)*\hlen}) {\footnotesize E$\flat$};
\node[circle,draw=gray,fill=gray!10,inner sep=0pt,minimum size=38pt] at ({(2*7+3-5)*\halfstep},{(5-5)*\hlen}) {\footnotesize F$\sharp$};
\node[circle,draw=gray,fill=gray!10,inner sep=0pt,minimum size=38pt] at ({(2*8+3-5)*\halfstep},{(5-5)*\hlen}) {\footnotesize A};
\node[circle,draw=gray,fill=gray!50,inner sep=0pt,minimum size=38pt] at ({(2*9+3-5)*\halfstep},{(5-5)*\hlen}) {\footnotesize C};
\node[circle,draw=gray,fill=gray!10,inner sep=0pt,minimum size=38pt] at ({(2*10+3-5)*\halfstep},{(5-5)*\hlen}) {\footnotesize E$\flat$};

% Row p=4 (y=hlen), r=1..9 – E at r=2,6; G at r=3,7
\node[circle,draw=gray,fill=gray!10,inner sep=0pt,minimum size=38pt] at ({(2*1+3-4)*\halfstep},{(5-4)*\hlen}) {\footnotesize C$\sharp$};
\node[circle,draw=gray,fill=gray!50,inner sep=0pt,minimum size=38pt] at ({(2*2+3-4)*\halfstep},{(5-4)*\hlen}) {\footnotesize E};
\node[circle,draw=gray,fill=gray!50,inner sep=0pt,minimum size=38pt] at ({(2*3+3-4)*\halfstep},{(5-4)*\hlen}) {\footnotesize G};
\node[circle,draw=gray,fill=gray!10,inner sep=0pt,minimum size=38pt] at ({(2*4+3-4)*\halfstep},{(5-4)*\hlen}) {\footnotesize B$\flat$};
\node[circle,draw=gray,fill=gray!10,inner sep=0pt,minimum size=38pt] at ({(2*5+3-4)*\halfstep},{(5-4)*\hlen}) {\footnotesize C$\sharp$};
\node[circle,draw=gray,fill=gray!50,inner sep=0pt,minimum size=38pt] at ({(2*6+3-4)*\halfstep},{(5-4)*\hlen}) {\footnotesize E};
\node[circle,draw=gray,fill=gray!50,inner sep=0pt,minimum size=38pt] at ({(2*7+3-4)*\halfstep},{(5-4)*\hlen}) {\footnotesize G};
\node[circle,draw=gray,fill=gray!10,inner sep=0pt,minimum size=38pt] at ({(2*8+3-4)*\halfstep},{(5-4)*\hlen}) {\footnotesize B$\flat$};
\node[circle,draw=gray,fill=gray!10,inner sep=0pt,minimum size=38pt] at ({(2*9+3-4)*\halfstep},{(5-4)*\hlen}) {\footnotesize C$\sharp$};

% Row p=3 (y=2*hlen), r=1..9
\node[circle,draw=gray,fill=gray!10,inner sep=0pt,minimum size=38pt] at ({(2*1+3-3)*\halfstep},{(5-3)*\hlen}) {\footnotesize D};
\node[circle,draw=gray,fill=gray!10,inner sep=0pt,minimum size=38pt] at ({(2*2+3-3)*\halfstep},{(5-3)*\hlen}) {\footnotesize F};
\node[circle,draw=gray,fill=gray!10,inner sep=0pt,minimum size=38pt] at ({(2*3+3-3)*\halfstep},{(5-3)*\hlen}) {\footnotesize A$\flat$};
\node[circle,draw=gray,fill=gray!10,inner sep=0pt,minimum size=38pt] at ({(2*4+3-3)*\halfstep},{(5-3)*\hlen}) {\footnotesize B};
\node[circle,draw=gray,fill=gray!10,inner sep=0pt,minimum size=38pt] at ({(2*5+3-3)*\halfstep},{(5-3)*\hlen}) {\footnotesize D};
\node[circle,draw=gray,fill=gray!10,inner sep=0pt,minimum size=38pt] at ({(2*6+3-3)*\halfstep},{(5-3)*\hlen}) {\footnotesize F};
\node[circle,draw=gray,fill=gray!10,inner sep=0pt,minimum size=38pt] at ({(2*7+3-3)*\halfstep},{(5-3)*\hlen}) {\footnotesize A$\flat$};
\node[circle,draw=gray,fill=gray!10,inner sep=0pt,minimum size=38pt] at ({(2*8+3-3)*\halfstep},{(5-3)*\hlen}) {\footnotesize B};
\node[circle,draw=gray,fill=gray!10,inner sep=0pt,minimum size=38pt] at ({(2*9+3-3)*\halfstep},{(5-3)*\hlen}) {\footnotesize D};

% Row p=2 (y=3*hlen), r=1..8 – C at r=4,8
\node[circle,draw=gray,fill=gray!10,inner sep=0pt,minimum size=38pt] at ({(2*1+3-2)*\halfstep},{(5-2)*\hlen}) {\footnotesize E$\flat$};
\node[circle,draw=gray,fill=gray!10,inner sep=0pt,minimum size=38pt] at ({(2*2+3-2)*\halfstep},{(5-2)*\hlen}) {\footnotesize F$\sharp$};
\node[circle,draw=gray,fill=gray!10,inner sep=0pt,minimum size=38pt] at ({(2*3+3-2)*\halfstep},{(5-2)*\hlen}) {\footnotesize A};
\node[circle,draw=gray,fill=gray!50,inner sep=0pt,minimum size=38pt] at ({(2*4+3-2)*\halfstep},{(5-2)*\hlen}) {\footnotesize C};
\node[circle,draw=gray,fill=gray!10,inner sep=0pt,minimum size=38pt] at ({(2*5+3-2)*\halfstep},{(5-2)*\hlen}) {\footnotesize E$\flat$};
\node[circle,draw=gray,fill=gray!10,inner sep=0pt,minimum size=38pt] at ({(2*6+3-2)*\halfstep},{(5-2)*\hlen}) {\footnotesize F$\sharp$};
\node[circle,draw=gray,fill=gray!10,inner sep=0pt,minimum size=38pt] at ({(2*7+3-2)*\halfstep},{(5-2)*\hlen}) {\footnotesize A};
\node[circle,draw=gray,fill=gray!50,inner sep=0pt,minimum size=38pt] at ({(2*8+3-2)*\halfstep},{(5-2)*\hlen}) {\footnotesize C};

% Row p=1 (top, y=4*hlen), r=1..8 – E at r=1,5; G at r=2,6
\node[circle,draw=gray,fill=gray!50,inner sep=0pt,minimum size=38pt] at ({(2*1+3-1)*\halfstep},{(5-1)*\hlen}) {\footnotesize E};
\node[circle,draw=gray,fill=gray!50,inner sep=0pt,minimum size=38pt] at ({(2*2+3-1)*\halfstep},{(5-1)*\hlen}) {\footnotesize G};
\node[circle,draw=gray,fill=gray!10,inner sep=0pt,minimum size=38pt] at ({(2*3+3-1)*\halfstep},{(5-1)*\hlen}) {\footnotesize B$\flat$};
\node[circle,draw=gray,fill=gray!10,inner sep=0pt,minimum size=38pt] at ({(2*4+3-1)*\halfstep},{(5-1)*\hlen}) {\footnotesize C$\sharp$};
\node[circle,draw=gray,fill=gray!50,inner sep=0pt,minimum size=38pt] at ({(2*5+3-1)*\halfstep},{(5-1)*\hlen}) {\footnotesize E};
\node[circle,draw=gray,fill=gray!50,inner sep=0pt,minimum size=38pt] at ({(2*6+3-1)*\halfstep},{(5-1)*\hlen}) {\footnotesize G};
\node[circle,draw=gray,fill=gray!10,inner sep=0pt,minimum size=38pt] at ({(2*7+3-1)*\halfstep},{(5-1)*\hlen}) {\footnotesize B$\flat$};
\node[circle,draw=gray,fill=gray!10,inner sep=0pt,minimum size=38pt] at ({(2*8+3-1)*\halfstep},{(5-1)*\hlen}) {\footnotesize C$\sharp$};

% ---- Row labels (reversed: p=5 bottom=1, p=1 top=5) on left of staff ----
% \staffleft = \xleft - 1.2; numbers at \xleft - 1.50 (right edge), TOP to the right of numbers at \xleft - 1.35
\foreach \p in {1,...,5} {
  \pgfmathtruncatemacro{\rlabel}{6-\p}
  \pgfmathsetmacro{\yy}{(5-\p)*\hlen}
  \node[anchor=east, font=\small] at ({\xleft - 1.50}, \yy) {\rlabel};
}
\node[anchor=center, rotate=90, font=\small\bfseries] at ({\xleft - 1.35}, {(\ytop)/2}) {TOP};

% ---- Treble staff above the grid ----
% Staff: 5 lines, gap=staffgap cm; bottom staff line (E4) above ytop
\pgfmathsetmacro{\staffgap}{0.25}                     % cm between staff lines
\pgfmathsetmacro{\staffbottom}{\ytop + 1.2}           % cm above grid top (gap between grid and staff)
\pgfmathsetmacro{\staffleft}{\xleft - 1.2}            % extended left to give room for clef before C4
\pgfmathsetmacro{\staffright}{\xright + 0.04}

\foreach \sl in {0,...,4} {
  \draw[black, thin] (\staffleft, \staffbottom + \sl*\staffgap)
                  -- (\staffright, \staffbottom + \sl*\staffgap);
}

% Treble clef – anchored at start of staff lines, raised so G-line sits on 2nd staff line
\node[anchor=base west, inner sep=0pt] at ({\staffleft + 0.04}, {\staffbottom + 2*\staffgap - 0.10}) {%
  \raisebox{-4pt}{\begingroup\normalmusicsize\fontsize{22}{22}\selectfont\trebleclef\endgroup}%
};

% ---- Notes above staff: chromatic C4..F#5 for columns k=3..21 ----
% CONFIGURATION: set \nvis = 1 to show, 0 to hide.
% \nacc sets the accidental label: {} = none, {$\sharp$} = sharp, {$\flat$} = flat.
% To change which notes are visible, edit the 1/0 values below.
% To change an accidental spelling (e.g. C# vs Db), change \nacc and the note y-position comment.
%
%                          vis  accidental       position note
\def\nvisIII{1}   \def\naccIII{}           % k= 3  C4    (ledger below staff)
\def\nvisIV{0}    \def\naccIV{$\sharp$}    % k= 4  C#4   (ledger below staff)
\def\nvisV{0}     \def\naccV{}             % k= 5  D4
\def\nvisVI{0}    \def\naccVI{$\flat$}     % k= 6  Eb4
\def\nvisVII{1}   \def\naccVII{}           % k= 7  E4
\def\nvisVIII{0}  \def\naccVIII{}          % k= 8  F4
\def\nvisIX{0}    \def\naccIX{$\sharp$}    % k= 9  F#4
\def\nvisX{1}     \def\naccX{}             % k=10  G4
\def\nvisXI{0}    \def\naccXI{$\flat$}     % k=11  Ab4
\def\nvisXII{0}   \def\naccXII{}           % k=12  A4
\def\nvisXIII{0}  \def\naccXIII{$\flat$}   % k=13  Bb4
\def\nvisXIV{0}   \def\naccXIV{}           % k=14  B4
\def\nvisXV{1}    \def\naccXV{}            % k=15  C5
\def\nvisXVI{0}   \def\naccXVI{$\sharp$}   % k=16  C#5
\def\nvisXVII{0}  \def\naccXVII{}          % k=17  D5
\def\nvisXVIII{0} \def\naccXVIII{$\flat$}  % k=18  Eb5
\def\nvisXIX{1}   \def\naccXIX{}           % k=19  E5
\def\nvisXX{0}    \def\naccXX{}            % k=20  F5
\def\nvisXXI{0}   \def\naccXXI{$\sharp$}   % k=21  F#5
%
\pgfmathsetmacro{\hstep}{\staffgap/2}  % cm per diatonic half-line
%
% k=3  C4 – pos=-2 (ledger below staff), stem up
\ifnum\nvisIII=1
  \draw[black,thin] ({0-0.20},{\staffbottom-2*\hstep}) -- ({0+0.20},{\staffbottom-2*\hstep});
  \filldraw[black] (0,{\staffbottom-2*\hstep}) ellipse (0.14 and 0.09);
  \draw[black,thin] ({0+0.13},{\staffbottom-2*\hstep}) -- ({0+0.13},{\staffbottom-2*\hstep+0.9});
  \node[anchor=base east,inner sep=0pt,font=\scriptsize] at ({0-0.12},{\staffbottom-2*\hstep+0.05}) {\naccIII};
\fi
%
% k=4  C#4 – pos=-2 (ledger below staff), stem up
\ifnum\nvisIV=1
  \draw[black,thin] ({(4-3)*\halfstep-0.20},{\staffbottom-2*\hstep}) -- ({(4-3)*\halfstep+0.20},{\staffbottom-2*\hstep});
  \filldraw[black] ({(4-3)*\halfstep},{\staffbottom-2*\hstep}) ellipse (0.14 and 0.09);
  \draw[black,thin] ({(4-3)*\halfstep+0.13},{\staffbottom-2*\hstep}) -- ({(4-3)*\halfstep+0.13},{\staffbottom-2*\hstep+0.9});
  \node[anchor=base east,inner sep=0pt,font=\scriptsize] at ({(4-3)*\halfstep-0.12},{\staffbottom-2*\hstep+0.05}) {\naccIV};
\fi
%
% k=5  D4  – pos=-1 (below bottom staff line), stem up
\ifnum\nvisV=1
  \filldraw[black] ({(5-3)*\halfstep},{\staffbottom-1*\hstep}) ellipse (0.14 and 0.09);
  \draw[black,thin] ({(5-3)*\halfstep+0.13},{\staffbottom-1*\hstep}) -- ({(5-3)*\halfstep+0.13},{\staffbottom-1*\hstep+0.9});
  \node[anchor=base east,inner sep=0pt,font=\scriptsize] at ({(5-3)*\halfstep-0.12},{\staffbottom-1*\hstep+0.05}) {\naccV};
\fi
%
% k=6  Eb4 – pos=0 (bottom staff line), stem up
\ifnum\nvisVI=1
  \filldraw[black] ({(6-3)*\halfstep},{\staffbottom+0*\hstep}) ellipse (0.14 and 0.09);
  \draw[black,thin] ({(6-3)*\halfstep+0.13},{\staffbottom}) -- ({(6-3)*\halfstep+0.13},{\staffbottom+0.9});
  \node[anchor=base east,inner sep=0pt,font=\scriptsize] at ({(6-3)*\halfstep-0.12},{\staffbottom+0.05}) {\naccVI};
\fi
%
% k=7  E4  – pos=0 (bottom staff line), stem up
\ifnum\nvisVII=1
  \filldraw[black] ({(7-3)*\halfstep},{\staffbottom+0*\hstep}) ellipse (0.14 and 0.09);
  \draw[black,thin] ({(7-3)*\halfstep+0.13},\staffbottom) -- ({(7-3)*\halfstep+0.13},{\staffbottom+0.9});
  \node[anchor=base east,inner sep=0pt,font=\scriptsize] at ({(7-3)*\halfstep-0.12},{\staffbottom+0.05}) {\naccVII};
\fi
%
% k=8  F4  – pos=1 (first space), stem up
\ifnum\nvisVIII=1
  \filldraw[black] ({(8-3)*\halfstep},{\staffbottom+1*\hstep}) ellipse (0.14 and 0.09);
  \draw[black,thin] ({(8-3)*\halfstep+0.13},{\staffbottom+1*\hstep}) -- ({(8-3)*\halfstep+0.13},{\staffbottom+1*\hstep+0.9});
  \node[anchor=base east,inner sep=0pt,font=\scriptsize] at ({(8-3)*\halfstep-0.12},{\staffbottom+1*\hstep+0.05}) {\naccVIII};
\fi
%
% k=9  F#4 – pos=1 (first space), stem up
\ifnum\nvisIX=1
  \filldraw[black] ({(9-3)*\halfstep},{\staffbottom+1*\hstep}) ellipse (0.14 and 0.09);
  \draw[black,thin] ({(9-3)*\halfstep+0.13},{\staffbottom+1*\hstep}) -- ({(9-3)*\halfstep+0.13},{\staffbottom+1*\hstep+0.9});
  \node[anchor=base east,inner sep=0pt,font=\scriptsize] at ({(9-3)*\halfstep-0.12},{\staffbottom+1*\hstep+0.05}) {\naccIX};
\fi
%
% k=10 G4  – pos=2 (second staff line), stem down
\ifnum\nvisX=1
  \filldraw[black] ({(10-3)*\halfstep},{\staffbottom+2*\hstep}) ellipse (0.14 and 0.09);
  \draw[black,thin] ({(10-3)*\halfstep-0.13},{\staffbottom+2*\hstep}) -- ({(10-3)*\halfstep-0.13},{\staffbottom+2*\hstep-0.9});
  \node[anchor=base east,inner sep=0pt,font=\scriptsize] at ({(10-3)*\halfstep-0.12},{\staffbottom+2*\hstep+0.05}) {\naccX};
\fi
%
% k=11 Ab4 – pos=3 (second space), stem down
\ifnum\nvisXI=1
  \filldraw[black] ({(11-3)*\halfstep},{\staffbottom+3*\hstep}) ellipse (0.14 and 0.09);
  \draw[black,thin] ({(11-3)*\halfstep-0.13},{\staffbottom+3*\hstep}) -- ({(11-3)*\halfstep-0.13},{\staffbottom+3*\hstep-0.9});
  \node[anchor=base east,inner sep=0pt,font=\scriptsize] at ({(11-3)*\halfstep-0.12},{\staffbottom+3*\hstep+0.05}) {\naccXI};
\fi
%
% k=12 A4  – pos=3 (second space), stem down
\ifnum\nvisXII=1
  \filldraw[black] ({(12-3)*\halfstep},{\staffbottom+3*\hstep}) ellipse (0.14 and 0.09);
  \draw[black,thin] ({(12-3)*\halfstep-0.13},{\staffbottom+3*\hstep}) -- ({(12-3)*\halfstep-0.13},{\staffbottom+3*\hstep-0.9});
  \node[anchor=base east,inner sep=0pt,font=\scriptsize] at ({(12-3)*\halfstep-0.12},{\staffbottom+3*\hstep+0.05}) {\naccXII};
\fi
%
% k=13 Bb4 – pos=4 (middle staff line), stem down
\ifnum\nvisXIII=1
  \filldraw[black] ({(13-3)*\halfstep},{\staffbottom+4*\hstep}) ellipse (0.14 and 0.09);
  \draw[black,thin] ({(13-3)*\halfstep-0.13},{\staffbottom+4*\hstep}) -- ({(13-3)*\halfstep-0.13},{\staffbottom+4*\hstep-0.9});
  \node[anchor=base east,inner sep=0pt,font=\scriptsize] at ({(13-3)*\halfstep-0.12},{\staffbottom+4*\hstep+0.05}) {\naccXIII};
\fi
%
% k=14 B4  – pos=4 (middle staff line), stem down
\ifnum\nvisXIV=1
  \filldraw[black] ({(14-3)*\halfstep},{\staffbottom+4*\hstep}) ellipse (0.14 and 0.09);
  \draw[black,thin] ({(14-3)*\halfstep-0.13},{\staffbottom+4*\hstep}) -- ({(14-3)*\halfstep-0.13},{\staffbottom+4*\hstep-0.9});
  \node[anchor=base east,inner sep=0pt,font=\scriptsize] at ({(14-3)*\halfstep-0.12},{\staffbottom+4*\hstep+0.05}) {\naccXIV};
\fi
%
% k=15 C5  – pos=5 (upper space), stem down
\ifnum\nvisXV=1
  \filldraw[black] ({(15-3)*\halfstep},{\staffbottom+5*\hstep}) ellipse (0.14 and 0.09);
  \draw[black,thin] ({(15-3)*\halfstep-0.13},{\staffbottom+5*\hstep}) -- ({(15-3)*\halfstep-0.13},{\staffbottom+5*\hstep-0.9});
  \node[anchor=base east,inner sep=0pt,font=\scriptsize] at ({(15-3)*\halfstep-0.12},{\staffbottom+5*\hstep+0.05}) {\naccXV};
\fi
%
% k=16 C#5 – pos=5 (upper space), stem down
\ifnum\nvisXVI=1
  \filldraw[black] ({(16-3)*\halfstep},{\staffbottom+5*\hstep}) ellipse (0.14 and 0.09);
  \draw[black,thin] ({(16-3)*\halfstep-0.13},{\staffbottom+5*\hstep}) -- ({(16-3)*\halfstep-0.13},{\staffbottom+5*\hstep-0.9});
  \node[anchor=base east,inner sep=0pt,font=\scriptsize] at ({(16-3)*\halfstep-0.12},{\staffbottom+5*\hstep+0.05}) {\naccXVI};
\fi
%
% k=17 D5  – pos=6 (fourth staff line), stem down
\ifnum\nvisXVII=1
  \draw[black,thin] ({(17-3)*\halfstep-0.20},{\staffbottom+6*\hstep}) -- ({(17-3)*\halfstep+0.20},{\staffbottom+6*\hstep});
  \filldraw[black] ({(17-3)*\halfstep},{\staffbottom+6*\hstep}) ellipse (0.14 and 0.09);
  \draw[black,thin] ({(17-3)*\halfstep-0.13},{\staffbottom+6*\hstep}) -- ({(17-3)*\halfstep-0.13},{\staffbottom+6*\hstep-0.9});
  \node[anchor=base east,inner sep=0pt,font=\scriptsize] at ({(17-3)*\halfstep-0.12},{\staffbottom+6*\hstep+0.05}) {\naccXVII};
\fi
%
% k=18 Eb5 – pos=7 (space above fourth line), stem down
\ifnum\nvisXVIII=1
  \draw[black,thin] ({(18-3)*\halfstep-0.20},{\staffbottom+6*\hstep}) -- ({(18-3)*\halfstep+0.20},{\staffbottom+6*\hstep});
  \filldraw[black] ({(18-3)*\halfstep},{\staffbottom+7*\hstep}) ellipse (0.14 and 0.09);
  \draw[black,thin] ({(18-3)*\halfstep-0.13},{\staffbottom+7*\hstep}) -- ({(18-3)*\halfstep-0.13},{\staffbottom+7*\hstep-0.9});
  \node[anchor=base east,inner sep=0pt,font=\scriptsize] at ({(18-3)*\halfstep-0.12},{\staffbottom+7*\hstep+0.05}) {\naccXVIII};
\fi
%
% k=19 E5  – pos=7 (space above fourth line), stem down
\ifnum\nvisXIX=1
  \draw[black,thin] ({(19-3)*\halfstep-0.20},{\staffbottom+6*\hstep}) -- ({(19-3)*\halfstep+0.20},{\staffbottom+6*\hstep});
  \filldraw[black] ({(19-3)*\halfstep},{\staffbottom+7*\hstep}) ellipse (0.14 and 0.09);
  \draw[black,thin] ({(19-3)*\halfstep-0.13},{\staffbottom+7*\hstep}) -- ({(19-3)*\halfstep-0.13},{\staffbottom+7*\hstep-0.9});
  \node[anchor=base east,inner sep=0pt,font=\scriptsize] at ({(19-3)*\halfstep-0.12},{\staffbottom+7*\hstep+0.05}) {\naccXIX};
\fi
%
% k=20 F5  – pos=8 (top staff line), stem down
\ifnum\nvisXX=1
  \draw[black,thin] ({(20-3)*\halfstep-0.20},{\staffbottom+6*\hstep}) -- ({(20-3)*\halfstep+0.20},{\staffbottom+6*\hstep});
  \draw[black,thin] ({(20-3)*\halfstep-0.20},{\staffbottom+8*\hstep}) -- ({(20-3)*\halfstep+0.20},{\staffbottom+8*\hstep});
  \filldraw[black] ({(20-3)*\halfstep},{\staffbottom+8*\hstep}) ellipse (0.14 and 0.09);
  \draw[black,thin] ({(20-3)*\halfstep-0.13},{\staffbottom+8*\hstep}) -- ({(20-3)*\halfstep-0.13},{\staffbottom+8*\hstep-0.9});
  \node[anchor=base east,inner sep=0pt,font=\scriptsize] at ({(20-3)*\halfstep-0.12},{\staffbottom+8*\hstep+0.05}) {\naccXX};
\fi
%
% k=21 F#5 – pos=8 (top staff line), stem down
\ifnum\nvisXXI=1
  \draw[black,thin] ({(21-3)*\halfstep-0.20},{\staffbottom+6*\hstep}) -- ({(21-3)*\halfstep+0.20},{\staffbottom+6*\hstep});
  \draw[black,thin] ({(21-3)*\halfstep-0.20},{\staffbottom+8*\hstep}) -- ({(21-3)*\halfstep+0.20},{\staffbottom+8*\hstep});
  \filldraw[black] ({(21-3)*\halfstep},{\staffbottom+8*\hstep}) ellipse (0.14 and 0.09);
  \draw[black,thin] ({(21-3)*\halfstep-0.13},{\staffbottom+8*\hstep}) -- ({(21-3)*\halfstep-0.13},{\staffbottom+8*\hstep-0.9});
  \node[anchor=base east,inner sep=0pt,font=\scriptsize] at ({(21-3)*\halfstep-0.12},{\staffbottom+8*\hstep+0.05}) {\naccXXI};
\fi

% ---- Connecting vertical lines from staff notes down to grid ----
% Draw a light vertical line from below each note head down to the top of the grid
% at the same x position (every k = every half-step)
\foreach \k in {3,...,21} {
  \pgfmathsetmacro{\nxx}{(\k-3)*\halfstep}
  \draw[lightgray!60, very thin] (\nxx, \ytop) -- (\nxx, {\staffbottom - 2*\hstep - 0.24});
}

% Bounding box
\pgfmathsetmacro{\bbleft}{\xleft - 1.75}
\pgfmathsetmacro{\bbtop}{\staffbottom + 8*\hstep + 0.6}
\useasboundingbox (\bbleft, \ybottom - 0.5) rectangle ({\xright + 0.15}, \bbtop);

